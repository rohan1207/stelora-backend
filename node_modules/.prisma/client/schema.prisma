generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BRAND
  INFLUENCER
  ADMIN
}

enum UserStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum CampaignMode {
  OPEN
  APPROVAL
  INVITE_ONLY
}

enum ProductStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum PartnershipStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

enum PayoutStatus {
  HELD
  RELEASED
  CANCELLED
}

enum PayoutRecordStatus {
  PENDING
  PROCESSING
  PAID
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  brandProfile      BrandProfile?
  influencerProfile InfluencerProfile?
  sentMessages      Message[]          @relation("SentMessages")
  receivedMessages  Message[]          @relation("ReceivedMessages")
  notifications     Notification[]
}

model BrandProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  logoUrl     String?
  website     String?
  niche       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

model InfluencerProfile {
  id                 String     @id @default(cuid())
  userId             String     @unique
  displayName        String
  username           String     @unique
  bio                String?
  avatarUrl          String?
  instagramHandle    String?
  followerCount      Int        @default(0)
  niche              String?
  verificationStatus UserStatus @default(PENDING)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponCodes  CouponCode[]
  partnerships Partnership[]
  payouts      Payout[]
}

model Product {
  id                String        @id @default(cuid())
  brandId           String
  name              String
  description       String?
  imageUrl          String?
  price             Decimal       @db.Decimal(10, 2)
  commissionPercent Decimal       @db.Decimal(5, 2)
  campaignMode      CampaignMode  @default(OPEN)
  status            ProductStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  brand        BrandProfile  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  couponCodes  CouponCode[]
  partnerships Partnership[]
  orders       Order[]
}

model Partnership {
  id           String            @id @default(cuid())
  influencerId String
  productId    String
  status       PartnershipStatus @default(PENDING)
  appliedAt    DateTime          @default(now())
  approvedAt   DateTime?
  updatedAt    DateTime          @updatedAt

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([influencerId, productId])
}

model CouponCode {
  id           String    @id @default(cuid())
  influencerId String
  productId    String
  code         String    @unique
  isActive     Boolean   @default(true)
  usageCount   Int       @default(0)
  totalRevenue Decimal   @default(0) @db.Decimal(12, 2)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@unique([influencerId, productId])
}

model Order {
  id               String       @id @default(cuid())
  couponCodeId     String
  productId        String
  customerEmail    String
  orderAmount      Decimal      @db.Decimal(10, 2)
  commissionAmount Decimal      @db.Decimal(10, 2)
  platformFee      Decimal      @db.Decimal(10, 2)
  status           OrderStatus  @default(CONFIRMED)
  payoutStatus     PayoutStatus @default(HELD)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  couponCode CouponCode @relation(fields: [couponCodeId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
}

model Payout {
  id           String             @id @default(cuid())
  influencerId String
  amount       Decimal            @db.Decimal(12, 2)
  status       PayoutRecordStatus @default(PENDING)
  periodStart  DateTime
  periodEnd    DateTime
  paidAt       DateTime?
  createdAt    DateTime           @default(now())

  influencer InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)
}

model Message {
  id            String    @id @default(cuid())
  senderId      String
  receiverId    String
  partnershipId String?
  body          String
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
